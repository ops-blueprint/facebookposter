# Copy this file to .env and fill in real values. Never commit the real .env.
FB_PAGE_ID=your_page_id_here
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here

# Instagram (separate from the Facebook Page credentials above)
IG_USER_ID=your_instagram_business_account_id_here
IG_ACCESS_TOKEN=your_access_token_with_instagram_content_publish_here
